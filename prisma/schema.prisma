generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  giangvien
  sinhvien
  doanhnghiep
}

enum EnterpriseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InternshipBatchStatus {
  OPEN
  CLOSED
}

enum WorkType {
  PART_TIME
  FULL_TIME
}

enum JobStatus {
  PENDING
  REJECTED
  ACTIVE
  STOPPED
}

enum JobApplicationStatus {
  PENDING_REVIEW
  INTERVIEW_INVITED
  OFFERED
  REJECTED
  STUDENT_DECLINED
}

enum JobApplicationResponse {
  PENDING
  ACCEPTED
  DECLINED
}

enum StudentInternshipStatus {
  NOT_STARTED
  DOING
  SELF_FINANCED
  REPORT_SUBMITTED
  COMPLETED
  REJECTED
}

enum InternshipReportReviewStatus {
  PENDING
  REJECTED
  APPROVED
}

enum StudentGender {
  MALE
  FEMALE
  OTHER
}

enum StudentDegree {
  BACHELOR
  ENGINEER
}

enum SupervisorDegree {
  MASTER
  PHD
  ASSOC_PROF
  PROF
}

enum SupervisorAssignmentStatus {
  GUIDING
  COMPLETED
}

model SupervisorAssignmentStatusHistory {
  id String @id @default(cuid())

  supervisorAssignmentId String

  fromStatus SupervisorAssignmentStatus
  toStatus SupervisorAssignmentStatus

  byRole Role
  message String?

  at DateTime @default(now())
  meta Json?

  supervisorAssignment SupervisorAssignment @relation(fields: [supervisorAssignmentId], references: [id])

  @@index([supervisorAssignmentId, at])
}

enum InternshipBatchSemester {
  HK_I
  HK_II
  HK_HE
  HK_PHU
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  phone              String?             @unique
  passwordHash       String
  fullName           String
  role               Role
  isLocked           Boolean             @default(false)
  enterpriseStatus   EnterpriseStatus?
  companyName        String?
  taxCode            String?             @unique
  representativeTitle String?
  enterpriseMeta     Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Recruitment module relations (only used by doanhnghiep / sinhvien roles).
  jobPosts         JobPost[]
  jobApplications  JobApplication[]

  // Student profile (only used by sinhvien role; managed by admin)
  studentProfile   StudentProfile?

  // Supervisor profile (only used by giangvien role; managed by admin)
  supervisorProfile SupervisorProfile?
}

model InternshipBatch {
  id        String                 @id @default(cuid())
  name      String                 // Tên đợt thực tập (hiển thị)
  semester  InternshipBatchSemester
  schoolYear String               // Ví dụ: 2024-2025
  status    InternshipBatchStatus @default(OPEN)
  startDate DateTime              // Thời gian bắt đầu
  endDate   DateTime              // Thời gian kết thúc
  notes     String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  jobPosts JobPost[]

  supervisorAssignments SupervisorAssignment[]

  @@unique([semester, schoolYear])
  @@unique([startDate, endDate])
}

model JobPost {
  id String @id @default(cuid())

  enterpriseUserId   String
  internshipBatchId  String

  title            String
  workType         WorkType
  recruitmentCount Int
  expertise        String

  salary                 String
  experienceRequirement String

  deadlineAt       DateTime // Hạn tuyển dụng

  jobDescription           String
  candidateRequirements    String
  benefits                 String
  workLocation             String
  workTime                 String
  applicationMethod       String?
  companyIntro     String?
  companyWebsite   String?

  status JobStatus @default(PENDING)
  rejectionReason String?

  stoppedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enterpriseUser  User               @relation(fields: [enterpriseUserId], references: [id])
  internshipBatch InternshipBatch   @relation(fields: [internshipBatchId], references: [id])

  jobApplications JobApplication[]
}

model JobApplication {
  id String @id @default(cuid())

  jobPostId String
  studentUserId String

  status JobApplicationStatus @default(PENDING_REVIEW)
  coverLetter String?
  cvUrl String?

  interviewAt DateTime?

  response JobApplicationResponse @default(PENDING)
  responseAt DateTime?

  history Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPost JobPost @relation(fields: [jobPostId], references: [id])
  studentUser User @relation(fields: [studentUserId], references: [id])

  @@unique([jobPostId, studentUserId])
}

model StudentProfile {
  id String @id @default(cuid())

  userId String @unique
  msv String @unique

  className String // Lớp
  faculty String // Khoa
  degree StudentDegree
  cohort String // Khóa (niên khóa)

  gender StudentGender
  birthDate DateTime

  permanentProvinceCode String
  permanentProvinceName String?
  permanentWardCode String
  permanentWardName String?

  currentProvinceCode String?
  currentProvinceName String?
  currentWardCode String?
  currentWardName String?

  intro String?
  cvFileName String?
  cvMime String?
  cvBase64 String?

  internshipStatus StudentInternshipStatus @default(NOT_STARTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  assignmentLinks SupervisorAssignmentStudent[]

  internshipReport InternshipReport?
  internshipStatusHistory InternshipStatusHistory[]
}

model SupervisorProfile {
  id String @id @default(cuid())

  userId String @unique
  faculty String
  degree SupervisorDegree

  gender StudentGender
  birthDate DateTime

  permanentProvinceCode String
  permanentProvinceName String?
  permanentWardCode String
  permanentWardName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  assignments SupervisorAssignment[]
}

model SupervisorAssignment {
  id String @id @default(cuid())

  faculty String
  status SupervisorAssignmentStatus @default(GUIDING)

  internshipBatchId String
  supervisorProfileId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  internshipBatch InternshipBatch @relation(fields: [internshipBatchId], references: [id])
  supervisorProfile SupervisorProfile @relation(fields: [supervisorProfileId], references: [id])

  students SupervisorAssignmentStudent[]

  statusHistory SupervisorAssignmentStatusHistory[]

  @@unique([internshipBatchId, supervisorProfileId])
}

model SupervisorAssignmentStudent {
  id String @id @default(cuid())

  supervisorAssignmentId String
  studentProfileId String

  createdAt DateTime @default(now())

  supervisorAssignment SupervisorAssignment @relation(fields: [supervisorAssignmentId], references: [id])
  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@unique([studentProfileId, supervisorAssignmentId])
}

model InternshipReport {
  id String @id @default(cuid())

  studentProfileId String @unique

  reportFileName String
  reportMime String
  reportBase64 String

  reviewStatus InternshipReportReviewStatus @default(PENDING)

  submittedAt DateTime @default(now())
  reviewedAt DateTime?

  supervisorRejectReason String?

  supervisorEvaluation String?
  supervisorPoint Float?

  enterpriseEvaluation String?
  enterprisePoint Float?

  history Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])
}

model InternshipStatusHistory {
  id String @id @default(cuid())

  studentProfileId String

  fromStatus StudentInternshipStatus
  toStatus StudentInternshipStatus

  byRole Role
  message String?

  at DateTime @default(now())

  meta Json?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@index([studentProfileId, at])
}
