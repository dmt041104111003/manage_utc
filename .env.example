# Copy to .env.local and fill in values.

# Used for JWT signing (session + password-reset tokens). Min 32 random bytes hex recommended.
SECRET=

# Neon / PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Gmail SMTP (app password)
EMAIL_FROM=
EMAIL_PASSWORD=

# Public URL for links inside emails
APP_URL=http://localhost:3000

# Logo email (HTTPS). NEXT_PUBLIC_* để preview React Email; SCHOOL_* dùng khi render trên server.
# Nên dùng ảnh nền trắng hoặc JPEG — PNG trong suốt hay bị client mail tô nền đen.
# SCHOOL_EMAIL_LOGO_URL=
# NEXT_PUBLIC_SCHOOL_EMAIL_LOGO_URL=

# Email hỗ trợ trong mẫu thư phê duyệt / từ chối (mặc định: phongdaotao@utc.edu.vn)
# SUPPORT_EMAIL=

# NEXT_PUBLIC_PREFILL_REGISTER=1
# Đăng ký base64 (tới ~45MB JSON): một số nền tải serverless giới hạn body nhỏ — khi deploy lỗi 413, cân nhắc upload file riêng hoặc S3.

# Cloudinary (CV upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Nên trùng CLOUDINARY_CLOUD_NAME (API proxy file dùng biến server trước; lệch cloud → tải GPK/CV 404).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
